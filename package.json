{
  "name": "easy-extension",
  "private": true,
  "version": "1.0.0",
  "description": "Easy Extension - React/Tailwind/CRXJS Chrome extension template",
  "type": "module",
  "scripts": {
    "dev": "npm run generate-icons && vite",
    "build": "npm run generate-icons && vite build --mode production",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "gen:content-script": "TMPDIR=.tmp tsx scripts/gen-content-script.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": " npm run type-check ; npm run lint:fix ; npm run format",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.45",
    "prettier": "^3.3.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^7.18.0",
    "vite": "^6.2.0"
  }
}
